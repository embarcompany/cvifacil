    {
      "parameters": {
        "jsCode": "const lead = $json;\n\nconst evoBaseUrl = 'https://evo.embarcompany.cloud';\nconst evoInstance = 'cvi';\nconst managerGroupJid = '120363426954252951@g.us';\n\nlet clientDigits = String(lead.whatsapp || '').replace(/\\D/g, '');\n\nif (clientDigits.length >= 10 && !clientDigits.startsWith('55')) {\n  clientDigits = `55${clientDigits}`;\n}\n\nconst destination = lead.destino_final || 'Destino nao informado';\nconst origin = lead.cidade_origem || 'Origem nao informada';\nconst travelWindow = lead.data_viagem || 'Previsao nao informada';\nconst petSummary = lead.pet_summary || 'Pet nao informado';\nconst createdAt = lead.created_at ? new Date(lead.created_at).toLocaleString('pt-BR', { timeZone: 'America/Sao_Paulo' }) : 'Agora';\nconst campaign = [lead.utm_source, lead.utm_medium, lead.utm_campaign].filter(Boolean).join(' / ') || 'Sem UTM';\n\nconst text = `Novo lead CVI Facil\\n\\nTutor: ${lead.nome_tutor || 'Nao informado'}\\nWhatsApp: ${lead.whatsapp || 'Nao informado'}\\nWhatsApp normalizado: ${clientDigits || 'Nao informado'}\\nEmail: ${lead.email_opcional || 'Nao informado'}\\n\\nOrigem: ${origin}\\nDestino: ${destination}\\nPrevisao: ${travelWindow}\\nPet: ${petSummary}\\n\\nCampanha: ${campaign}\\nCriado em: ${createdAt}\\nLead ID: ${lead.id}\\n\\nAcionar o tutor pelo WhatsApp acima.`;\n\nreturn [{\n  json: {\n    ...lead,\n    client_whatsapp_normalized: clientDigits,\n    manager_group_jid: managerGroupJid,\n    evo_base_url: evoBaseUrl.replace(/\\/$/, ''),\n    evo_instance: evoInstance,\n    evo_message: text\n  }\n}];"
      },
      "id": "prepare-message",
      "name": "Preparar alerta gestor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -200,
        240
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$json.evo_base_url}}/message/sendText/{{$json.evo_instance}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "apikey",
              "value": "COLE_A_API_KEY_DA_EVO_AQUI"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "bodyParameters": {
          "parameters": [
            {
              "name": "number",
              "value": "={{$json.manager_group_jid}}"
            },
            {
              "name": "text",
              "value": "={{$json.evo_message}}"
            },
            {
              "name": "delay",
              "value": "={{1200}}"
            },
            {
              "name": "linkPreview",
              "value": "={{false}}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "responseFormat": "json"
            }
          }
        }
      },
      "id": "send-evo-message",
      "name": "Evo HTTP - Enviar para grupo",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        60,
        240
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead = $('Preparar alerta gestor').item.json;\nconst response = $json?.data || $json;\nconst messageId = response?.key?.id || response?.messageId || response?.id || response?.response?.key?.id || null;\n\nreturn [{\n  json: {\n    lead_id: lead.id,\n    evo_message_id: messageId,\n    evo_instance: lead.evo_instance\n  }\n}];"
      },
      "id": "prepare-update",
      "name": "Preparar update",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
